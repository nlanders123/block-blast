{
    "appId": "com.blockblast.app",
    "appName": "Block Blast",
    "webDir": ".",
    "bundledWebRuntime": false,
    "server": {
        "androidScheme": "https"
    },
    "plugins": {
        "SplashScreen": {
            "launchShowDuration": 2000,
            "backgroundColor": "#0A0E27",
            "showSpinner": false
